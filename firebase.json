{
  "hosting": {
    "public": "cloud/frontend/dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
          { "key": "X-Content-Type-Options", "value": "nosniff" }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "run": {
          "serviceId": "scan-api",
          "region": "us-central1"
        }
      },
      {
        "source": "/quote/**",
        "run": {
          "serviceId": "scan-api",
          "region": "us-central1"
        }
      },
      {
        "source": "/embed/**",
        "run": {
          "serviceId": "scan-api",
          "region": "us-central1"
        }
      },
      {
        "source": "/splat/**",
        "run": {
          "serviceId": "scan-api",
          "region": "us-central1"
        }
      },
      {
        "source": "/bids/**",
        "run": {
          "serviceId": "scan-api",
          "region": "us-central1"
        }
      },
      {
        "source": "/admin/**",
        "run": {
          "serviceId": "scan-api",
          "region": "us-central1"
        }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
